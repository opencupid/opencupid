{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "module": "ESNext",
    "target": "ES2020",
    "typeRoots": ["./types", "./node_modules/@types"],
    "paths": {
      "@/*": ["./src/*"],
      "@zod/*": ["../../packages/shared/zod/*"],
      "@shared/*": ["../../packages/shared/*"]
    },
    "types": ["node"]
  },
  "include": ["src", "types", "scripts", "src/**/*.vue"]
}
