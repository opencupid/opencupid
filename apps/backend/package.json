{
  "name": "@opencupid/backend",
  "main": "dist/api.js",
  "version": "0.61.0",
  "scripts": {
    "dev": "vite build && rm -rf dist && concurrently -n api,worker -c blue,magenta --kill-others-on-fail \"tsup src/api.ts --watch --no-clean --onSuccess 'node --inspect dist/api.js'\" \"tsup src/worker.ts --watch --no-clean --onSuccess 'node dist/worker.js'\"",
    "build": "vite build && tsup && tsup --config tsup.scripts.config.ts",
    "build:ssr": "vite build",
    "start": "node dist/api.js",
    "start:worker": "node dist/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate  dev",
    "prisma:seed": "prisma db seed",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "watch": "tsc-watch",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write src/",
    "images:reprocess": "npx tsx scripts/reprocess-images.ts",
    "redis:flush": "docker compose exec redis redis-cli FLUSHALL",
    "redis:sessions": "docker compose exec redis  redis-cli KEYS '*'",
    "tags:translate": "npx node scripts/translate-tags-deepl.js",
    "db:psql": "docker compose exec db sh -c 'psql -U $POSTGRES_USER $POSTGRES_DB'",
    "db:restore": "docker compose exec -T db sh -c 'psql -U $POSTGRES_USER $POSTGRES_DB'",
    "db:dump": "docker compose exec db sh -c 'pg_dump --data-only --no-privileges --disable-triggers -U $POSTGRES_USER $POSTGRES_DB'",
    "db:backup": "docker compose exec db sh -c 'pg_dump --clean -U $POSTGRES_USER $POSTGRES_DB'",
    "dump:tags": "docker compose exec backend node scripts/dump-tags.js",
    "type-check": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:i18n": "npx i18n-check --locales ../../packages/shared/i18n/ -s en --only missingKeys --exclude **/api/**",
    "test:coverage": "pnpm run test --coverage --coverage.reporter=text-summary"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.6",
    "@bull-board/fastify": "^6.20.6",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "11.2.0",
    "@fastify/jwt": "10.0.0",
    "@fastify/multipart": "9.4.0",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/static": "9.1.3",
    "@fastify/websocket": "11.2.0",
    "@prisma/client": "6.15.0",
    "@sentry/node": "10.52.0",
    "@tensorflow-models/face-detection": "1.0.3",
    "@tensorflow/tfjs": "4.22.0",
    "@tensorflow/tfjs-backend-cpu": "4.22.0",
    "@vue/server-renderer": "3.5.34",
    "altcha-lib": "1.4.1",
    "bcrypt": "6.0.0",
    "blurhash": "^2.0.5",
    "bullmq": "5.76.6",
    "cuid": "3.0.0",
    "deepl-node": "1.27.0",
    "dotenv": "17.4.2",
    "dotenv-expand": "12.0.3",
    "fast-jwt": "^6.2.4",
    "fastify": "5.8.5",
    "fastify-plugin": "5.1.0",
    "i18next": "25.8.13",
    "i18next-fs-backend": "2.6.5",
    "i18next-icu": "^2.4.3",
    "ioredis": "5.10.1",
    "jsdom": "28.1.0",
    "juice": "^11.1.1",
    "nanoid": "^5.1.11",
    "nanoid-dictionary": "^5.0.0",
    "nodemailer": "8.0.7",
    "pino": "10.3.1",
    "prisma": "6.15.0",
    "sharp": "0.34.5",
    "slugify": "1.6.9",
    "smartcrop-sharp": "^2.0.8",
    "supercluster": "^8.0.1",
    "ts-node": "10.9.2",
    "undici": "7.22.0",
    "vue": "3.5.34",
    "web-push": "3.6.7",
    "ws": "8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.28.0",
    "@faker-js/faker": "9.8.0",
    "@types/bcrypt": "6.0.0",
    "@types/mime-types": "3.0.1",
    "@types/node": "24.12.3",
    "@types/nodemailer": "6.4.17",
    "@types/supercluster": "^7.1.3",
    "@types/web-push": "3.6.4",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitest/coverage-v8": "4.1.5",
    "axios": "1.16.0",
    "concurrently": "9.2.1",
    "eslint": "10.3.0",
    "globals": "17.6.0",
    "mime-types": "3.0.2",
    "nyc": "18.0.0",
    "pino-pretty": "13.1.3",
    "prisma-zod-generator": "0.8.13",
    "ts-node-dev": "2.0.0",
    "tsc-watch": "7.2.0",
    "tsconfig-paths": "4.2.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2",
    "vite": "6.3.5",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.5",
    "wscat": "6.1.0",
    "zod-prisma-types": "^3.3.11"
  }
}
