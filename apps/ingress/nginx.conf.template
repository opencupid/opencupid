worker_processes 1;
env AUTH_IMG_HMAC_SECRET;
env CSP_REPORT_URI;

events {
  worker_connections 1024;
}

error_log /dev/stderr error;

http {
  include mime.types;
  default_type application/octet-stream;

  sendfile on;
  keepalive_timeout 65;

  # --- Enable Gzip ---
  gzip on;
  gzip_comp_level 6;
  gzip_min_length 256;
  gzip_vary on;
  gzip_proxied any;
  gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript font/woff2;

  # --- Shared security headers (called from each server block) ---
  init_by_lua_block {
    function set_security_headers(extra_csp)
      ngx.header["X-Content-Type-Options"] = "nosniff"
      ngx.header["X-Frame-Options"] = "DENY"
      ngx.header["Referrer-Policy"] = "strict-origin-when-cross-origin"
      ngx.header["Permissions-Policy"] = "camera=(), microphone=(self), geolocation=()"

      local csp = "default-src 'self'"
        .. "; script-src 'self' https://*.${DOMAIN}"
        .. "; style-src 'self' 'unsafe-inline'"
        .. "; img-src 'self' data: blob:"
        .. "; font-src 'self'"
        .. "; object-src 'none'"
        .. "; base-uri 'self'"
        .. "; form-action 'self'"
        .. "; frame-ancestors 'none'"

      if extra_csp and extra_csp ~= "" then
        csp = csp .. "; " .. extra_csp
      end

      local report_uri = os.getenv("CSP_REPORT_URI")
      if report_uri and report_uri ~= "" then
        csp = csp .. "; report-uri " .. report_uri
      end

      csp = csp .. "; upgrade-insecure-requests"

      ngx.header["Content-Security-Policy"] = csp
    end
  }

  # --- Upstreams ---
  upstream backend {
    server backend:3000;
  }

  upstream frontend {
    server frontend:3001;
  }

  upstream jitsi-web {
    server jitsi-web:80;
  }

  upstream admin {
    server admin:3002;
  }

  upstream listmonk {
    server listmonk:9000;
  }

  # --- HTTP -> HTTPS Redirect ---
  server {
    listen 80;
    server_name _;

    location /.well-known/acme-challenge/ {
      root /var/www/html;
      try_files $uri =404;
    }

    location / {
      return 301 https://$host$request_uri;
    }
  }

  # --- Reject unknown Host headers ---
  server {
    listen 443 ssl default_server;
    ssl_reject_handshake on;
  }

  # --- HTTPS Server ---
  server {
    listen 443 ssl;
    server_name ${DOMAIN};

    ssl_certificate     /etc/letsencrypt/live/${DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${DOMAIN}/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # Security headers (set via Lua to apply to all locations including those with add_header)
    header_filter_by_lua_block {
      set_security_headers(
        "worker-src 'self' blob:"
        .. "; media-src 'self'"
        .. "; frame-src https://*.${DOMAIN}"
        .. "; connect-src 'self' wss://${DOMAIN} https://*.${DOMAIN}"
      )
    }

    # Default limit for everything else (1MB by default, or set explicitly)
    client_max_body_size 1M;

    # Block admin API on public domain — only accessible via mTLS admin domain
    location /api/admin/ {
      return 404;
    }

    # Image and voice message upload endpoints (larger body size for file uploads)
    location /api/image {
      client_max_body_size 20M;

      proxy_pass http://backend;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Admin-Authenticated "";
    }

    location /api/messages/voice {
      client_max_body_size 20M;

      proxy_pass http://backend;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Admin-Authenticated "";
    }

    location /api/ {
      proxy_pass http://backend;
      proxy_http_version 1.1;
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection "upgrade";
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Admin-Authenticated "";
    }

    location /ws/ {
      proxy_pass http://backend;
      proxy_http_version 1.1;
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection "upgrade";
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

      proxy_read_timeout 3600;
      proxy_send_timeout 3600;

    }

    location /user-content/ {
      access_by_lua_file media_auth.lua;
      alias /var/www/;
      autoindex off;
      try_files $uri =404;
      add_header Cache-Control "public, max-age=31536000, immutable";
    }

    location /.well-known/acme-challenge/ {
      root /var/www/html;
    }

    location / {
      proxy_pass http://frontend/;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
  }

  # --- Jitsi Meet (subdomain) ---
  server {
    listen 443 ssl;
    server_name meet.${DOMAIN};

    ssl_certificate     /etc/letsencrypt/live/${DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${DOMAIN}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    location /xmpp-websocket {
      proxy_pass http://jitsi-web/xmpp-websocket;
      proxy_http_version 1.1;
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection "upgrade";
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location /colibri-ws {
      proxy_pass http://jitsi-web/colibri-ws;
      proxy_http_version 1.1;
      proxy_set_header Upgrade $http_upgrade;
      proxy_set_header Connection "upgrade";
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location / {
      proxy_pass http://jitsi-web/;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
  }

  # --- HTTPS Listmonk Public Server ---
  server {
    listen 443 ssl;
    server_name ${LISTMONK_DOMAIN};

    ssl_certificate     /etc/letsencrypt/live/${DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${DOMAIN}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    client_max_body_size 10M;

    location / {
      proxy_pass http://listmonk;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Forwarded-Proto $scheme;
    }
  }

  # --- HTTPS Admin Server (mTLS) ---
  server {
    listen 443 ssl;
    server_name ${ADMIN_DOMAIN};

    ssl_certificate     /etc/letsencrypt/live/${DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${DOMAIN}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    ssl_client_certificate /etc/nginx/client-ca.crt;
    ssl_verify_client on;

    # Security headers for admin
    header_filter_by_lua_block {
      set_security_headers("connect-src 'self'")
    }

    location /api/ {
      proxy_pass http://backend;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      proxy_set_header X-Admin-Authenticated true;
    }

    location / {
      proxy_pass http://admin/;
      proxy_http_version 1.1;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
      proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
  }
}