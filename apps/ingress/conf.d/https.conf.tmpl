# --- HTTP -> HTTPS Redirect ---
server {
  listen 80;
  server_name _;

  location /.well-known/acme-challenge/ {
    root /var/www/html;
    try_files $uri =404;
  }

  location / {
    return 301 https://$host$request_uri;
  }
}

# --- Reject unknown Host headers ---
server {
  listen 443 ssl default_server;
  ssl_reject_handshake on;
}

# --- HTTPS Server ---
server {
  listen 443 ssl;
  server_name ${DOMAIN};

  ssl_certificate     /etc/letsencrypt/live/${DOMAIN}/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/${DOMAIN}/privkey.pem;

  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_ciphers HIGH:!aNULL:!MD5;

  limit_conn conn_per_ip 20;
  limit_req  zone=req_per_ip burst=50 nodelay;
  limit_req_status 429;
  limit_conn_status 429;

  # --- Security headers ---
  set $public_csp "default-src 'self'; script-src 'self' https://*.${DOMAIN}; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; worker-src 'self' blob:; media-src 'self' blob:; frame-src https://*.${DOMAIN}; img-src 'self' data: blob: ${CSP_ALLOWED_DOMAINS}; connect-src 'self' blob: wss://${DOMAIN} https://*.${DOMAIN} ${CSP_ALLOWED_DOMAINS}; upgrade-insecure-requests${CSP_REPORT_DIRECTIVE}";
  include conf.d/security-headers.conf;
  add_header Content-Security-Policy $public_csp always;

  # Default limit for everything else (1MB by default, or set explicitly)
  client_max_body_size 1M;

  # Block admin API on public domain — only accessible via mTLS admin domain
  location /api/admin/ {
    return 404;
  }

  # Block bull-board on public domain — only accessible via mTLS admin domain.
  # Unlike /api/ routes, this path is not proxied here so there is no
  # proxy_set_header to clear the X-Admin-Authenticated header; the 404
  # ensures the backend is never reached at all.
  location /bull-board {
    return 404;
  }

  # --- Scanner / exploit-probe honeypots (return 444 = drop connection) ---
  location ~* \.(php|asp|aspx|cgi|pl|py|rb|jsp|jspx|env|git|sql|bak|old|zip|tar|gz)$ {
    return 444;
  }
  location ~* ^/(wp-admin|wp-login\.php|xmlrpc\.php|wp-content|wp-includes|phpmyadmin|pma|meta.json|\.env|\.git|\.env) {
    return 444;
  }

  # Image and voice message upload endpoints (larger body size for file uploads)
  location /api/image {
    client_max_body_size 20M;

    proxy_pass http://backend:3000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Admin-Authenticated "";
  }

  location /api/messages/voice {
    client_max_body_size 20M;

    proxy_pass http://backend:3000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Admin-Authenticated "";
  }

  location /api/ {
    proxy_pass http://backend:3000;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Admin-Authenticated "";
  }

  location /ws/ {
    proxy_pass http://backend:3000;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

    proxy_read_timeout 3600;
    proxy_send_timeout 3600;
  }

  location /user-content/ {
    auth_jwt $cookie___session;
    auth_jwt_key "${JWT_SECRET}" utf8;
    auth_jwt_alg HS256;

    # Repeat security headers — add_header in a location overrides server-level
    include conf.d/security-headers.conf;
    add_header Content-Security-Policy $public_csp always;
    add_header Cache-Control "public, max-age=31536000, immutable";

    alias /var/www/;
    autoindex off;
    try_files $uri =404;
  }

  location /.well-known/acme-challenge/ {
    root /var/www/html;
  }

  location / {
    proxy_pass http://frontend:3001/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  }
}

# --- Jitsi Meet (subdomain) ---
server {
  listen 443 ssl;
  server_name meet.${DOMAIN};

  ssl_certificate     /etc/letsencrypt/live/${DOMAIN}/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/${DOMAIN}/privkey.pem;
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_ciphers HIGH:!aNULL:!MD5;

  location /xmpp-websocket {
    proxy_pass http://jitsi-web:80/xmpp-websocket;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  }

  location /colibri-ws {
    proxy_pass http://jitsi-web:80/colibri-ws;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  }

  location / {
    proxy_pass http://jitsi-web:80/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  }
}

# --- HTTPS Admin Server (mTLS) ---
server {
  listen 443 ssl;
  server_name ${ADMIN_DOMAIN};

  ssl_certificate     /etc/letsencrypt/live/${DOMAIN}/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/${DOMAIN}/privkey.pem;
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_ciphers HIGH:!aNULL:!MD5;

  ssl_client_certificate /etc/nginx/client-ca.crt;
  ssl_verify_client on;

  # Security headers for admin
  include conf.d/security-headers.conf;
  add_header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self' data: blob:; connect-src 'self'; upgrade-insecure-requests${CSP_REPORT_DIRECTIVE}" always;

  location /api/ {
    proxy_pass http://backend:3000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Admin-Authenticated true;
  }

  location /bull-board {
    proxy_pass http://backend:3000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Admin-Authenticated true;
  }

  location / {
    proxy_pass http://admin:3002/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  }
}
