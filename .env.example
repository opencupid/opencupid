NODE_ENV=development

# Docker Compose file override (uncomment in production)
# COMPOSE_FILE=docker-compose.production.yml

# Core URLs and ports
# For Terraform-based staging deploys you can use ${SUBDOMAIN_FQDN} here.
# deployment/deploy.sh runs envsubst and replaces ${SUBDOMAIN_FQDN} with terraform output.
# For fixed environments, set full URLs/domains directly instead.
FRONTEND_URL=https://app.example.org:5173
BACKEND_PORT=3000
API_BASE_URL=/api
WS_BASE_URL=/ws

# Database
DATABASE_URL=postgresql://appuser:secret@localhost:5432/app

# Postgres container (production only)
POSTGRES_DB=app
POSTGRES_USER=appuser
POSTGRES_PASSWORD=secret
POSTGRES_DATADIR=/srv/pgdata

# Redis
REDIS_URL=redis://localhost:6379

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test@example.org
SMTP_PASS=secret
EMAIL_FROM="Test App <hello@example.org>"

# Media
MEDIA_UPLOAD_DIR=/srv/uploads
MEDIA_URL_BASE=/user-content
IMAGE_MAX_SIZE=10485760

# Voice messages (max recording duration in seconds, shared between frontend and backend)
VOICE_MESSAGE_MAX_DURATION=120

# Profile that sends the automatic welcome message
ADMIN_PROFILE_ID=

# Site identity and Open Graph meta tags
# OG URLs can reference ${SUBDOMAIN_FQDN} (expanded by deployment/deploy.sh).
SITE_NAME=OpenCupid
OG_TITLE="OpenCupid"
OG_DESCRIPTION="OpenCupid open source matchmaking application"
OG_IMAGE=https://app.example.org/og-image.png
OG_URL=https://app.example.org
OG_TYPE=website

# Domain / ingress (used by Traefik reverse proxy)
# Either set concrete domains, or use ${SUBDOMAIN_FQDN} token:
# DOMAIN=${SUBDOMAIN_FQDN}
# ADMIN_DOMAIN=admin.${SUBDOMAIN_FQDN}
DOMAIN=example.org
ADMIN_DOMAIN=admin.example.org
EMAIL=admin@example.org
# Path to the CA certificate used to verify admin client TLS certificates
ADMIN_CA_CERT_FILE=/srv/admin-ca/ca.crt

# Additional frontend origins for CORS (comma-separated, optional).
# Set when running multiple frontend instances on different domains.
# FRONTEND_URLS=https://site-a.com,https://site-b.com
FRONTEND_URLS=

# OpenReplay session replay (optional — tracker only loads when both are set)
OPENREPLAY_PROJECT_KEY=
OPENREPLAY_INGEST_POINT=

# Sentry
SENTRY_DSN=
# CSP violation report endpoint (e.g. Sentry CSP endpoint). Leave empty to disable reporting.
CSP_REPORT_URI=
# Space-separated list of external API origins allowed in CSP connect-src
CSP_ALLOWED_DOMAINS="https://photon.komoot.io https://nominatim.openstreetmap.org https://api.maptiler.com https://maps.hereapi.com"

# Map tiles — full template URL with API key; use {z}/{x}/{y} placeholders (Leaflet tileLayer)
# Example (HERE): https://maps.hereapi.com/v3/base/mc/{z}/{x}/{y}/png?apiKey=YOUR_KEY&style=lite.day&size=512
MAP_TILE_URL=
# Attribution text shown in the map control (required by most tile providers' ToS)
MAP_ATTRIBUTION=

# Geocoding country allowlist (comma-separated ISO 3166-1 alpha-2 codes). Empty = all countries.
GEOCODING_ALLOWED_COUNTRIES=AT,BE,BG,CY,CZ,DE,DK,EE,ES,FI,FR,GR,HR,HU,IE,IT,LT,LU,LV,MT,NL,PL,PT,RO,SE,SI,SK,PH

# Jitsi video calls (subdomain of DOMAIN, proxied through ingress on 443)
# Can be tokenized: JITSI_DOMAIN=meet.${SUBDOMAIN_FQDN}
JITSI_DOMAIN=meet.example.org
JICOFO_AUTH_PASSWORD=jicofo_secret
JVB_AUTH_PASSWORD=jvb_secret
# Public IP of the Docker host (used by JVB for media routing).
# For local dev, set to your machine's IP. deploy.sh substitutes ${SERVER_IP} automatically.
JVB_ADVERTISE_IPS=${SERVER_IP}

# DeepL API key for tag translations (optional)
DEEPL_API_KEY=

# GeoIP lookup service — observabilitystack/geoip-api
# https://hub.docker.com/r/observabilitystack/geoip-api
# Default targets the `geoip-api` service in docker-compose.
GEOIP_API_URL=http://geoip-api:8086

# Tolgee (translation management) — development only
# In-context editing: install Tolgee Chrome Plugin, Alt+click any string
TOLGEE_API_URL=http://localhost:8085
TOLGEE_API_KEY=

# Dev auth bypass — enables GET /auth/dev/latest-token (never set in production)
DEV_AUTH_BYPASS_ENABLED=false

# Docker image registry prefix (used by docker-compose.production.yml)
DOCKER_IMAGE_PREFIX=ghcr.io/opencupid/opencupid

# Per-image versions (used by docker-compose.production.yml)
BACKEND_VERSION=latest
FRONTEND_VERSION=latest
ADMIN_VERSION=latest
INGRESS_VERSION=latest

# Secrets — generate with: node scripts/generate-secrets.mjs
JWT_SECRET=supersecret
UNSUBSCRIBE_SECRET=unsubscribe_hmac_secret
ALTCHA_HMAC_KEY=your_altcha_hmac_key
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
