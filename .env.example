NODE_ENV=development

# Docker Compose file override (uncomment in production)
# COMPOSE_FILE=docker-compose.production.yml

# Core URLs and ports
FRONTEND_URL=https://app.example.org:5173
BACKEND_PORT=3000
API_BASE_URL=/api
WS_BASE_URL=/ws
JWT_SECRET=supersecret

# Database
DATABASE_URL=postgresql://appuser:secret@localhost:5432/app

# for postgres (production only)
POSTGRES_DB=app
POSTGRES_USER=appuser
POSTGRES_PASSWORD=secret
POSTGRES_DATADIR=/srv/pgdata

# redis
REDIS_URL=redis://localhost:6379

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test@example.org
SMTP_PASS=secret
EMAIL_FROM="Test App <hello@example.org>"

# Media
MEDIA_UPLOAD_DIR=/srv/uploads
MEDIA_URL_BASE=/user-content
IMAGE_MAX_SIZE=10485760
IMAGE_URL_HMAC_TTL_SECONDS=300
AUTH_IMG_HMAC_SECRET=your_hmac_secret

# SMS
SMS_API_KEY=xxxxxx

# CAPTCHA
ALTCHA_HMAC_KEY=5f47e36b-2b14-4f49-b6f1-df47b8f8c4a9

# VAPID
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Sentry
SENTRY_DSN=
# CSP violation report endpoint (e.g. Sentry CSP endpoint). Leave empty to disable reporting.
CSP_REPORT_URI=

MAXMIND_ACCOUNT_ID=1234
MAXMIND_LICENSE_KEY=your_license_key

TYPEAHEAD_DEBOUNCE_MS=300

# Voice messages
VOICE_MESSAGE_MAX_DURATION=120

# allowed # of profile scope updates per day
RATE_LIMIT_PROFILE_SCOPES=1

# Profile that sends the automatic welcome message
WELCOME_MESSAGE_SENDER_PROFILE_ID=

# Google credentials path for translation API
GOOGLE_APPLICATION_CREDENTIALS=/tmp/gcp.json

# Open Graph meta tags
OG_TITLE="OpenCupid"
OG_DESCRIPTION="OpenCupid is an open-source dating platform."
OG_IMAGE=https://app.example.org/og-image.png
OG_URL=https://app.example.org
OG_TYPE=website

# For production used by nginx reverse proxy and certbot
DOMAIN=example.org
ADMIN_DOMAIN=admin.example.org
EMAIL=admin@example.org
CERTBOT_ETCDIR=/srv/certbot
# Path to the CA certificate used to verify admin client TLS certificates
ADMIN_CA_CERT_FILE=/srv/admin-ca/ca.crt

# Name of the site
SITE_NAME=OpenCupid

# DeepL API key for tag translations (optional)
DEEPL_API_KEY=

# Jitsi video call domain (subdomain of DOMAIN, proxied through ingress on 443)
JITSI_DOMAIN=meet.example.org
JICOFO_AUTH_PASSWORD=jicofo_secret
JVB_AUTH_PASSWORD=jvb_secret
# Public IP of the Docker host (used by JVB for media routing)
JVB_ADVERTISE_IPS=

# OpenStreetMap tiles
TILE_UPSTREAM="https://{s}.tile.openstreetmap.org"
TILE_SUBDOMAINS="a,b,c"
TILE_USER_AGENT="OpenCupid/1.0 (+https://example.org; contact thebot@example.org)"
TILE_REFERER="https://example.org"
TILE_CACHE_ITEMS=500              # LRU size (in-memory)
TILE_MAX_AGE_SECONDS=86400        # down & client cache TTL
TILE_TIMEOUT_MS=15000             # Request timeout for upstream tiles
TILE_RETRIES=2                    # Number of retries for failed requests

# Docker image registry prefix and tag (used by docker-compose.production.yml)
DOCKER_IMAGE_PREFIX=ghcr.io/opencupid/opencupid
DOCKER_IMAGE_TAG=latest
