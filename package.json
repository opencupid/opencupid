{
  "name": "opencupid",
  "version": "0.17.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@lingual/i18n-check": "^0.8.19",
    "@modelcontextprotocol/server-filesystem": "2026.1.14",
    "@sentry/cli": "1.77.3",
    "@tolgee/cli": "^2.16.1",
    "@types/geojson": "7946.0.16",
    "acorn": "8.16.0",
    "dotenv-expand": "12.0.3",
    "prettier": "3.8.1",
    "turbo": "2.8.10"
  },
  "scripts": {
    "ci:test": "pnpm install && pnpm --filter backend prisma:generate && pnpm lint && pnpm type-check && pnpm --filter frontend exec pnpm build-only && pnpm --filter backend exec vitest run && pnpm --filter frontend exec vitest run && pnpm test:i18n",
    "dev": "./scripts/dev-start.sh",
    "dev:stop": "./scripts/dev-stop.sh",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check --concurrency 1",
    "format": "turbo run format",
    "gen-certs": "openssl req -x509 -nodes -days 365   -newkey rsa:2048   -keyout certs/localhost-key.pem   -out certs/localhost-cert.pem   -subj \"/C=US/ST=Dev/L=Local/O=Dev/CN=localhost\"",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "test:i18n": "turbo run test:i18n",
    "translate:icu": "npx json-autotranslate -i packages/shared/i18n/ --directory-structure ngx-translate -d --type key-based -m icu -s deepl-free -c ${DEEPL_API_KEY},less,1000",
    "translate:i18next": "npx json-autotranslate -i packages/shared/i18n/api --directory-structure ngx-translate -d --type key-based -m i18next -s deepl-free -c ${DEEPL_API_KEY},less,1000",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "tolgee:push": "set -a && . ./.env && tolgee push",
    "tolgee:pull": "set -a && . ./.env && tolgee pull"
  },
  "dependencies": {
    "@types/node": "22.16.1",
    "extendable-media-recorder": "^9.2.36",
    "extendable-media-recorder-wav-encoder": "^7.0.136",
    "rollup": "4.59.0",
    "zod": "3.24.4"
  },
  "pnpm": {
    "overrides": {
      "tsx": "4.21.0",
      "vue": "3.5.28",
      "@vue/server-renderer": "3.5.28",
      "vite-plugin-vue-mcp": "0.3.2",
      "vite-plugin-vue-mcp>@modelcontextprotocol/sdk": "1.22.0",
      "zod-to-json-schema": "3.24.5"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@sentry/cli",
      "bcrypt",
      "canvas",
      "core-js",
      "esbuild",
      "prisma",
      "protobufjs",
      "sharp",
      "vue-demi"
    ],
    "patchedDependencies": {
      "vite-plugin-vue-mcp@0.3.2": "patches/vite-plugin-vue-mcp@0.3.2.patch"
    }
  },
  "packageManager": "pnpm@10.30.1"
}
