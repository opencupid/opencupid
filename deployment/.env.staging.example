NODE_ENV=production
COMPOSE_FILE=docker-compose.production.yml

# Core URLs — replace staging.example.org with your actual staging domain
FRONTEND_URL=https://staging.example.org
BACKEND_PORT=3000
API_BASE_URL=/api
WS_BASE_URL=/ws
JWT_SECRET=FILL_IN_RANDOM_SECRET

# Database
DATABASE_URL=postgresql://appuser:FILL_IN@db:5432/app
POSTGRES_DB=app
POSTGRES_USER=appuser
POSTGRES_PASSWORD=FILL_IN
POSTGRES_DATADIR=/srv/pgdata

# Redis
REDIS_URL=redis://redis:6379

# Email (SMTP) — use a real provider or MailHog/MailPit for staging
SMTP_HOST=FILL_IN
SMTP_PORT=587
SMTP_USER=FILL_IN
SMTP_PASS=FILL_IN
EMAIL_FROM="OpenCupid Staging <noreply@staging.example.org>"

# Media
MEDIA_UPLOAD_DIR=/srv/uploads
MEDIA_URL_BASE=/user-content
IMAGE_MAX_SIZE=10485760
IMAGE_URL_HMAC_TTL_SECONDS=300
AUTH_IMG_HMAC_SECRET=FILL_IN_RANDOM_SECRET

# SMS (can use test/dummy key for staging)
SMS_API_KEY=FILL_IN

# CAPTCHA
ALTCHA_HMAC_KEY=FILL_IN_UUID

# VAPID (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=FILL_IN
VAPID_PRIVATE_KEY=FILL_IN

# Sentry (optional for staging — leave empty to disable)
SENTRY_DSN=
CSP_REPORT_URI=

# MaxMind (optional for staging)
MAXMIND_ACCOUNT_ID=FILL_IN
MAXMIND_LICENSE_KEY=FILL_IN

TYPEAHEAD_DEBOUNCE_MS=300
VOICE_MESSAGE_MAX_DURATION=120
RATE_LIMIT_PROFILE_SCOPES=1
WELCOME_MESSAGE_SENDER_PROFILE_ID=

GOOGLE_APPLICATION_CREDENTIALS=/tmp/gcp.json

# Open Graph
OG_TITLE="OpenCupid Staging"
OG_DESCRIPTION="OpenCupid staging environment"
OG_IMAGE=https://staging.example.org/og-image.png
OG_URL=https://staging.example.org
OG_TYPE=website

# Nginx / Certbot — must match your staging domain
DOMAIN=staging.example.org
ADMIN_DOMAIN=admin.staging.example.org
EMAIL=admin@example.org
CERTBOT_ETCDIR=/srv/certbot
ADMIN_CA_CERT_FILE=/srv/admin-ca/ca.crt

SITE_NAME="OpenCupid Staging"

DEEPL_API_KEY=

# Jitsi
JITSI_DOMAIN=meet.staging.example.org
JICOFO_AUTH_PASSWORD=FILL_IN_RANDOM
JVB_AUTH_PASSWORD=FILL_IN_RANDOM
# Set this to the server IP after `terraform output server_ip`
JVB_ADVERTISE_IPS=FILL_IN_SERVER_IP

MAPTILER_API_KEY=FILL_IN

# Docker image registry
DOCKER_IMAGE_PREFIX=ghcr.io/opencupid/opencupid
BACKEND_VERSION=latest
FRONTEND_VERSION=latest
ADMIN_VERSION=latest
INGRESS_VERSION=latest
