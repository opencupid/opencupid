# Hetzner Cloud API token — https://console.hetzner.cloud → project → Security → API Tokens
hcloud_token = "FILL_IN"

# Your current public IP in CIDR notation — https://ifconfig.me → append /32
management_cidr = "1.2.3.4/32"

# Domain used to derive DNS zone for generated deployment hostnames.
# example.org -> zone example.org
# staging.example.org -> zone example.org
subdomain_fqdn = "staging.example.org"

# Server size. cx32 = 4 vCPU / 8 GB RAM. Minimum for full stack.
server_type = "cx32"

# Datacenter. fsn1=Falkenstein, nbg1=Nuremberg, hel1=Helsinki, ash=Ashburn
server_location = "fsn1"
