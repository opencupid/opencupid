# Tolgee CLI API key — dev only, points to localhost:8085
# Auto-generated on first startup via tolgee.import.create-implicit-api-key
TOLGEE_API_KEY=opencupid-admin-imported-project-implicit

# To enable the dev auth bypass endpoint (GET /auth/dev/latest-token),
# set DEV_AUTH_BYPASS_ENABLED=true in the root .env file (this file is only loaded by Vite/frontend).
