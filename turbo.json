{
  "$schema": "https://turbo.build/schema.json",
  "noUpdateNotifier": true,
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {},
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:coverage": {},
    "test:i18n": {},
    "lint": {},
    "generate": {
      "outputs": []
    },
    "migrate": {
      "outputs": []
    },
    "format": {
      "outputs": []
    },
    "type-check": {}
  }
}
