{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@prisma/client": ["./apps/backend/node_modules/@prisma/client"],
      "@zod/*": ["./packages/shared/zod/*"]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./apps/backend/node_modules/@types",
      "./packages/shared/node_modules/@types"
    ]
  },
  "include": ["packages", "apps", "types"]
}
